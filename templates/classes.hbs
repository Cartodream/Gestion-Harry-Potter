<div class="hp4-classes-wrapper">
  <nav class="hp4-year-tabs">
    {{#each years}}
      <button type="button" class="hp4-year-tab" data-year="{{yearKey}}">{{label}}</button>
    {{/each}}
  </nav>

  <div class="hp4-year-panels">
    {{#each years}}
      <div class="hp4-year-panel hp4-year-drop" data-year="{{yearKey}}">
        <h3>{{label}}</h3>

        {{#if ../isGM}}
          <p class="hp4-hint"><i class="fas fa-info-circle"></i> Glissez des acteurs depuis le répertoire</p>
        {{/if}}

        <div class="hp4-actors-grid">
          {{#each actors}}
            <div class="hp4-actor-card">
              <img src="{{img}}" alt="{{name}}" />
              <span>{{name}}</span>
              {{#if ../../isGM}}
                <button type="button" class="hp4-remove-actor" data-id="{{id}}" title="Retirer">
                  <i class="fas fa-times"></i>
                </button>
              {{/if}}
            </div>
          {{else}}
            <p class="hp4-empty">Aucun élève dans cette année.</p>
          {{/each}}
        </div>
      </div>
    {{/each}}
  </div>
</div>